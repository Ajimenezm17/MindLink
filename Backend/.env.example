# Copia a .env y ajusta (no subas .env al repositorio).

# --- Django ---
DJANGO_SECRET_KEY=cambiar-en-produccion
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- PostgreSQL ---
# Local Docker: DB_HOST=db | Local sin Docker: DB_HOST=localhost | Neon: host del panel Connect
DB_NAME=tfgdb
DB_USER=tfguser
DB_PASSWORD=tfgpwd123
DB_HOST=localhost
DB_PORT=5432
DB_SSL=

# --- Chatbot ---
# auto | groq | ollama | gemini | rules
CHATBOT_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
